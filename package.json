{
  "name": "@rolster/rollup",
  "version": "1.1.0",
  "type": "module",
  "description": "Package containing the basic definitions for handling data types.",
  "license": "MIT",
  "author": "Rolster Technology <rolster.developments@gmail.com>",
  "contributors": [
    {
      "name": "Daniel Andrés Castillo Pedroza",
      "email": "ing.dacastillop@gmail.com"
    }
  ],
  "types": "./index.d.ts",
  "main": "./index.cjs.js",
  "module": "./index.es.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "node": {
        "require": "./index.cjs.js",
        "import": "./index.es.js"
      },
      "import": "./index.es.js"
    }
  },
  "files": [
    "index.cjs.js",
    "index.cjs.js.map",
    "index.es.js",
    "index.es.js.map",
    "index.d.ts"
  ],
  "scripts": {
    "prettier": "prettier --write \"*.{ts,js}\"",
    "build": "rollup -c rollup.config.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "^25.0.4",
    "@rollup/plugin-node-resolve": "^15.2.1",
    "@rollup/plugin-typescript": "^11.1.3",
    "rollup": "^4.59.0"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "prettier": "^3.8.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rolster-developments/typescript-rollup.git"
  },
  "keywords": [
    "rolster",
    "typescript",
    "rollup"
  ],
  "publishConfig": {
    "access": "public"
  }
}
